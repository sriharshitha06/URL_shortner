# PORT: Optional. HTTP port for the Express server.
PORT=3000

# DATABASE_URL: Required. PostgreSQL connection string for persistent URL storage.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/upsk_sdf

# API_KEYS: Required. JSON map of API keys to principal ids for protected endpoints.
API_KEYS={"dev-key-a":"A","dev-key-b":"B"}

# USE_IN_MEMORY_STORE: Optional. Set to true to run without PostgreSQL for local auth-only checks.
USE_IN_MEMORY_STORE=false
